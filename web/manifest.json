{
  "manifest_version": 3,
  "name": "YouTube RPC",
  "version": "1.0.0",
  "description": "Discord Rich Presence for all major YouTube services.",
  "permissions": ["nativeMessaging", "tabs"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://music.youtube.com/*",
    "https://tv.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://music.youtube.com/*",
        "https://tv.youtube.com/*"
      ],
      "js": ["content/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://music.youtube.com/*",
        "https://tv.youtube.com/*"
      ],
      "js": ["content/service.js", "content/mediasession.js", "content/observer.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["pages/*", "icons/*", "content/inject.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "youtuberpc@PLACEHOLDER"
    }
  }
}
